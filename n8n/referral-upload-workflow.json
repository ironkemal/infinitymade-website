            "position": [
                250,
                400
            ],
            "typeVersion": 1,
            "webhookId": "9a136b09-1b13-4fff-b205-9040b863d5a8"
        },
        {
            "parameters": {
                "functionCode": "const businessId = $input.first().json.body.business_id;\nconst dateNow = $input.first().json.dateNow;\nconst uuid = $input.first().json.uuid;\nconst filename = `referral_${dateNow}_${uuid}.jpg`;\nconst publicUrl = `https://n8n.infinitymade.de/webhook/referral-image?business_id=${businessId}&filename=${filename}`;\nreturn {\n  json: {\n    ...$input.first().json,\n    filename: filename,\n    imageUrl: publicUrl,\n    businessId: businessId,\n    modelTried: []\n  }\n};"
            },
            "id": "set-vars",
            "name": "Set Variables",
            "type": "n8n-nodes-base.set",
            "position": [
                450,
                400
            ]
        },
        {
            "parameters": {
                "command": "cat > /home/n8n/referrals/{{ $json.businessId }}/{{ $json.filename }}",
                "note": "Dosyayı VPS'e kaydet"
            },
            "id": "write-file",
