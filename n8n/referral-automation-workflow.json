                        },
                        {
                            "name": "patient_geburtsdatum",
                            "value": "={{ $json.parsedData.dogum_tarihi }}"
                        },
                        {
                            "name": "seans_sayisi",
                            "value": "={{ $json.parsedData.seans_sayisi }}"
                        },
                        {
                            "name": "tedavi_turu",
                            "value": "={{ $json.parsedData.tedavi_turu }}"
                        },
                        {
                            "name": "hausbesuch",
                            "value": "={{ $json.parsedData.hausbesuch }}"
                        },
                        {
                            "name": "diagnose",
                            "value": "={{ $json.parsedData.diagnose }}"
                        },
                        {
                            "name": "arzt_name",
                            "value": "={{ $json.parsedData.arzt_name }}"
                        },
                        {
                            "name": "image_url",
                            "value": "={{ $json.storageUrl }}"
                        },
                        {
                            "name": "status",
                            "value": "pending"
                        }
                    ]
                },
                "options": {}
            },
            "id": "db-insert",
            "name": "Supabase - Kaydet",
            "type": "n8n-nodes-base.httpRequest",
            "position": [
                1000,
                300
            ]
        },
        {
            "parameters": {
                "functionCode": "// JSON Parse\nconst response = $input.first().json;\n\n// AI yanıtından JSON çıkar\nlet aiContent = response.choices?.[0]?.message?.content || '';\n\n// Markdown kod bloklarını temizle\naiContent = aiContent.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n\nlet parsedData;\ntry {\n  parsedData = JSON.parse(aiContent);\n} catch (e) {\n  // JSON parse hatası\n  throw new Error('AI response is not valid JSON: ' + aiContent);\n}\n\nreturn {\n  json: {\n    ...$input.first().json,\n    parsedData: parsedData\n  }\n};"
            },
            "id": "parse-json",
            "name": "JSON Parse",
            "type": "n8n-nodes-base.function",
            "position": [
                850,
                300
            ]
        },
        {
            "parameters": {
                "conditions": {
                    "options": {
                        "caseSensitive": true,
                        "leftValue": "",
                        "typeValidation": "strict"
                    },
                    "conditions": [
                        {
                            "id": "draft-created",
                            "leftValue": "{{ $json.draftId }}",
                            "rightValue": "",
                            "operator": "exists"
                        }
                    ],
                    "combinator": "and"
                },
                "options": {}
            },
            "id": "check-success",
            "name": "Başarılı mı?",
            "type": "n8n-nodes-base.switch",
            "position": [
                1200,
                300
            ]
        }
    ],
