          "content": {
            "size": 8045,
            "mimeType": "text/html",
            "text": "<!DOCTYPE html>\n<html lang=\"de\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Termin Buchen - Infinity Calendar</title>\n  <link rel=\"stylesheet\" href=\"dashboard.css\">\n  <link href=\"https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap\" rel=\"stylesheet\">\n  <style>\n    :root { --bg-primary: #0f1115; --bg-card: #16181d; --bg-secondary: #1a1d24; --text-primary: #f8fafc; --text-secondary: #94a3b8; --border: rgba(255,255,255,0.08); --accent: #22c55e; }\n    body { font-family: 'Outfit', sans-serif; background-color: var(--bg-primary); display: flex; justify-content: center; align-items: center; min-height: 100vh; margin: 0; padding: 20px; box-sizing: border-box; color: var(--text-primary); }\n    .booking-container { background-color: var(--bg-card); border: 1px solid var(--border); border-radius: 16px; width: 100%; max-width: 900px; display: flex; overflow: hidden; min-height: 600px; box-shadow: 0 10px 40px rgba(0,0,0,0.6); }\n    .sidebar { width: 300px; padding: 30px; border-right: 1px solid var(--border); background: var(--bg-secondary); }\n    .main-content { flex: 1; padding: 30px; overflow-y: auto; }\n    \n    .list-btn { display: block; width: 100%; text-align: left; background: var(--bg-card); border: 1px solid var(--border); padding: 15px; border-radius: 12px; margin-bottom: 12px; cursor: pointer; color: var(--text-primary); transition: all 0.2s; }\n    .list-btn:hover { border-color: var(--accent); transform: translateY(-2px); }\n    .list-btn.active { border-color: var(--accent); background-color: rgba(34, 197, 94, 0.1); box-shadow: 0 4px 15px rgba(34, 197, 94, 0.1); }\n    \n    .slots-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(100px, 1fr)); gap: 10px; margin-top: 20px; }\n    .slot-btn { background: var(--bg-secondary); border: 1px solid var(--border); padding: 12px 10px; border-radius: 8px; color: var(--text-primary); cursor: pointer; text-align: center; font-weight: 500; font-family:inherit; transition: 0.2s; }\n    .slot-btn:hover { border-color: var(--accent); color: var(--accent); }\n    .slot-btn.selected { background: var(--accent); border-color: var(--accent); color: #000; font-weight: 600; }\n    \n    .step { display: none; animation: fadeIn 0.3s ease; }\n    .step.active { display: block; }\n    @keyframes fadeIn { from { opacity: 0; transform: translateY(5px); } to { opacity: 1; transform: translateY(0); } }\n    \n    .biz-logo { width: 70px; height: 70px; border-radius: 50%; background: var(--accent); display: flex; align-items: center; justify-content: center; font-size: 28px; font-weight: bold; color: #000; margin-bottom: 20px; box-shadow: 0 4px 20px rgba(34, 197, 94, 0.3); }\n    \n    .sel-info { margin-top: 30px; display: none; padding-top:20px; border-top:1px solid var(--border); }\n    .sel-info h4 { margin-bottom: 15px; color: var(--text-secondary); font-size: 13px; text-transform: uppercase; letter-spacing: 1px; }\n    .sel-row { margin-bottom: 12px; display: flex; flex-direction: column; }\n    .sel-label { font-size: 11px; color: var(--text-secondary); text-transform: uppercase; }\n    .sel-val { font-weight: 600; color: #fff; font-size: 15px; }\n\n    input.form-control { background: rgba(0,0,0,0.3); border: 1px solid var(--border); color: #fff; padding: 12px; border-radius: 8px; font-family: inherit; width: 100%; box-sizing:border-box; margin-bottom: 20px;}\n    input.form-control:focus { outline: none; border-color: var(--accent); }\n    label { display: block; margin-bottom: 8px; font-size: 13px; color: var(--text-secondary); }\n\n    .btn-primary { background: var(--accent); color: #000; border: none; padding: 14px 20px; border-radius: 8px; font-weight: 600; cursor: pointer; transition: 0.2s; font-family:inherit; }\n    .btn-primary:hover:not(:disabled) { box-shadow: 0 4px 15px rgba(34, 197, 94, 0.4); transform: translateY(-2px); }\n    .btn-primary:disabled { opacity: 0.5; cursor: not-allowed; }\n    .btn-ghost { background: transparent; color: var(--text-secondary); border: none; cursor: pointer; padding: 5px 0; font-family:inherit;}\n    .btn-ghost:hover { color: #fff; }\n\n    @media (max-width: 768px) { .booking-container { flex-direction: column; } .sidebar { width: 100%; border-right: none; border-bottom: 1px solid var(--border); } }\n  </style>\n</head>\n<body>\n\n  <div class=\"booking-container\">\n    <div class=\"sidebar\">\n      <div class=\"biz-logo\" id=\"bizLogo\">?</div>\n      <h2 id=\"bizName\" style=\"margin-top:0; font-weight:600;\">Laden...</h2>\n      <p class=\"text-muted\" style=\"color:var(--text-secondary); font-size:14px;\">Buchen Sie Ihren Termin in wenigen Schritten.</p>\n      \n      <div id=\"selectedInfo\" class=\"sel-info\">\n        <h4>Ihre Auswahl</h4>\n        <div class=\"sel-row\" id=\"row-emp\" style=\"display:none;\"><span class=\"sel-label\">Mitarbeiter</span><span class=\"sel-val\" id=\"selEmp\"></span></div>\n        <div class=\"sel-row\" id=\"row-srv\" style=\"display:none;\"><span class=\"sel-label\">Dienstleistung</span><span class=\"sel-val\" id=\"selServiceTitle\"></span></div>\n        <div class=\"sel-row\" id=\"row-date\" style=\"display:none;\"><span class=\"sel-label\">Zeitpunkt</span><span class=\"sel-val\" id=\"selDate\"></span></div>\n      </div>\n    </div>\n\n    <div class=\"main-content\">\n      \n      <!-- Step 1: Employee Selection -->\n      <div id=\"step-employees\" class=\"step active\">\n        <h3 style=\"margin-bottom:20px; font-weight:500;\">1. Person auswählen</h3>\n        <div id=\"publicEmployeeList\">\n          <p style=\"color:var(--text-secondary);\">Mitarbeiter werden geladen...</p>\n        </div>\n      </div>\n\n      <!-- Step 2: Service Selection -->\n      <div id=\"step-services\" class=\"step\">\n        <button class=\"btn-ghost\" onclick=\"goStep('employees')\" style=\"margin-bottom:20px;\">&larr; Zurück</button>\n        <h3 style=\"margin-bottom:20px; font-weight:500;\">2. Dienstleistung wählen</h3>\n        <div id=\"publicServicesList\"></div>\n      </div>\n\n      <!-- Step 3: Date & Time Selection -->\n      <div id=\"step-datetime\" class=\"step\">\n        <button class=\"btn-ghost\" onclick=\"goStep('services')\" style=\"margin-bottom:20px;\">&larr; Zurück</button>\n        <h3 style=\"margin-bottom:20px; font-weight:500;\">3. Datum & Uhrzeit wählen</h3>\n        \n        <input type=\"date\" id=\"datePicker\" class=\"form-control\" />\n        \n        <div id=\"slotsContainer\" class=\"slots-grid\"></div>\n        \n        <div style=\"margin-top:40px; text-align:right;\">\n          <button class=\"btn-primary\" id=\"btnNextToForm\" disabled>Weiter zu Schritt 4 &rarr;</button>\n        </div>\n      </div>\n\n      <!-- Step 4: Customer Details Form -->\n      <div id=\"step-form\" class=\"step\">\n        <button class=\"btn-ghost\" onclick=\"goStep('datetime')\" style=\"margin-bottom:20px;\">&larr; Zurück</button>\n        <h3 style=\"margin-bottom:20px; font-weight:500;\">4. Ihre Kontaktdaten</h3>\n        \n        <form id=\"bookingForm\">\n          <label>Vollständiger Name</label>\n          <input type=\"text\" id=\"custName\" class=\"form-control\" required />\n          \n          <label>E-Mail Adresse</label>\n          <input type=\"email\" id=\"custEmail\" class=\"form-control\" required />\n          \n          <label>Telefonnummer</label>\n          <input type=\"tel\" id=\"custPhone\" class=\"form-control\" required />\n          \n          <div style=\"margin-top:30px;\">\n            <button type=\"submit\" class=\"btn-primary\" style=\"width:100%;\">Termin verbindlich buchen</button>\n          </div>\n        </form>\n      </div>\n      \n      <!-- Step 5: Success -->\n      <div id=\"step-success\" class=\"step\" style=\"text-align:center; padding-top:60px;\">\n        <div style=\"font-size:70px; margin-bottom:20px;\">✨</div>\n        <h2 style=\"font-weight:600; margin-bottom:10px;\">Termin bestätigt!</h2>\n        <p style=\"color:var(--text-secondary);\">Wir freuen uns auf Sie. Sie erhalten in Kürze eine Bestätigung per E-Mail.</p>\n      </div>\n\n    </div>\n  </div>\n\n  <script type=\"module\" src=\"booking.js?v=20260509\"></script>\n</body>\n</html>\n"
          },
