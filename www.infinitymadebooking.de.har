            "mimeType": "text/css",
            "text": ":root {\n  --bg-primary: #0a0a0a;\n  --bg-secondary: #111111;\n  --bg-card: #1a1a1a;\n  --bg-card-hover: #222222;\n  --border: rgba(255, 255, 255, 0.08);\n  --border-strong: rgba(255, 255, 255, 0.16);\n  --text-primary: #f5f5f5;\n  --text-secondary: #a0a0a0;\n  --text-muted: #6b6b6b;\n  --accent: #22c55e;\n  --accent-hover: #16a34a;\n  --accent-soft: rgba(34, 197, 94, 0.1);\n  --danger: #ef4444;\n  --warning: #f59e0b;\n}\n\n* { box-sizing: border-box; margin: 0; padding: 0; }\n\nhtml, body {\n  background: var(--bg-primary);\n  color: var(--text-primary);\n  font-family: 'Inter', -apple-system, sans-serif;\n  -webkit-font-smoothing: antialiased;\n  min-height: 100vh;\n}\n\nbutton { font-family: inherit; cursor: pointer; }\na { color: inherit; text-decoration: none; }\n\n/* LOADING */\n.loading-screen {\n  position: fixed; inset: 0;\n  display: flex; align-items: center; justify-content: center;\n  background: var(--bg-primary);\n  z-index: 100;\n}\n.spinner {\n  width: 40px; height: 40px;\n  border: 3px solid var(--border);\n  border-top-color: var(--accent);\n  border-radius: 50%;\n  animation: spin 0.8s linear infinite;\n}\n@keyframes spin { to { transform: rotate(360deg); } }\n\n/* TOPBAR */\n.topbar {\n  height: 64px;\n  background: var(--bg-secondary);\n  border-bottom: 1px solid var(--border);\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  padding: 0 24px;\n  position: sticky;\n  top: 0;\n  z-index: 20;\n}\n\n.topbar-left, .topbar-right { display: flex; align-items: center; gap: 16px; }\n\n.brand {\n  font-size: 1.15rem;\n  font-weight: 800;\n  letter-spacing: -0.02em;\n}\n.brand:hover { color: var(--accent); }\n\n.biz-name {\n  color: var(--text-secondary);\n  font-size: 0.92rem;\n  font-weight: 500;\n}\n\n.lang-select {\n  background: var(--bg-card);\n  color: var(--text-primary);\n  border: 1px solid var(--border);\n  padding: 6px 10px;\n  border-radius: 8px;\n  font-family: inherit;\n  font-size: 0.82rem;\n  cursor: pointer;\n}\n\n.logout-btn {\n  background: transparent;\n  color: var(--text-secondary);\n  border: 1px solid var(--border);\n  padding: 7px 14px;\n  border-radius: 8px;\n  font-size: 0.85rem;\n  font-weight: 500;\n  transition: all 0.2s;\n}\n.logout-btn:hover { color: var(--danger); border-color: var(--danger); }\n\n.hamburger {\n  display: none;\n  background: transparent;\n  border: none;\n  flex-direction: column;\n  gap: 4px;\n  padding: 8px;\n}\n.hamburger span {\n  width: 22px; height: 2px;\n  background: var(--text-primary);\n  border-radius: 2px;\n}\n\n/* LAYOUT */\n.dashboard-layout {\n  display: grid;\n  grid-template-columns: 220px 1fr;\n  min-height: calc(100vh - 64px);\n}\n\n/* SIDEBAR */\n.sidebar {\n  background: var(--bg-secondary);\n  border-right: 1px solid var(--border);\n  padding: 24px 12px;\n  position: sticky;\n  top: 64px;\n  height: calc(100vh - 64px);\n  overflow-y: auto;\n}\n\n.sidebar nav {\n  display: flex;\n  flex-direction: column;\n  gap: 4px;\n}\n\n.sidebar-item {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n  padding: 10px 14px;\n  color: var(--text-secondary);\n  border-radius: 8px;\n  font-size: 0.9rem;\n  font-weight: 500;\n  transition: all 0.15s;\n  background: transparent;\n  border: none;\n  width: 100%;\n  text-align: left;\n}\n.sidebar-item:hover {\n  background: var(--bg-card);\n  color: var(--text-primary);\n}\n.sidebar-item.active {\n  background: var(--accent-soft);\n  color: var(--accent);\n}\n.sidebar-item .icon { font-size: 1rem; }\n.sidebar-item .lock {\n  margin-left: auto;\n  font-size: 0.75rem;\n  opacity: 0.6;\n}\n\n/* MAIN */\n.main-area {\n  padding: 32px;\n  max-width: 1200px;\n  width: 100%;\n}\n\n.panel { animation: fadeIn 0.3s; }\n@keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: none; } }\n\n.panel h2 {\n  font-size: 1.6rem;\n  font-weight: 700;\n  letter-spacing: -0.02em;\n  margin-bottom: 8px;\n}\n\n.panel-sub {\n  color: var(--text-secondary);\n  margin-bottom: 24px;\n  font-size: 0.95rem;\n}\n\n/* KPI CARDS */\n.kpi-grid {\n  display: grid;\n  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));\n  gap: 16px;\n  margin: 24px 0 32px;\n}\n\n.kpi-card {\n  background: var(--bg-card);\n  border: 1px solid var(--border);\n  border-radius: 12px;\n  padding: 20px;\n}\n\n.kpi-label {\n  font-size: 0.78rem;\n  color: var(--text-muted);\n  font-weight: 500;\n  text-transform: uppercase;\n  letter-spacing: 0.05em;\n  margin-bottom: 8px;\n}\n\n.kpi-value {\n  font-size: 1.25rem;\n  font-weight: 700;\n  color: var(--text-primary);\n}\n\n.kpi-value.support-mail {\n  font-size: 0.95rem;\n  color: var(--accent);\n  font-weight: 500;\n  word-break: break-all;\n}\n\n/* CARD */\n.card {\n  background: var(--bg-card);\n  border: 1px solid var(--border);\n  border-radius: 12px;\n  padding: 24px;\n  margin-bottom: 16px;\n}\n\n.card h3 {\n  font-size: 1.1rem;\n  font-weight: 600;\n  margin-bottom: 16px;\n}\n\n.feature-list {\n  list-style: none;\n  display: grid;\n  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));\n  gap: 8px;\n}\n\n.feature-list li {\n  display: flex;\n  gap: 10px;\n  padding: 8px 0;\n  font-size: 0.92rem;\n  color: var(--text-secondary);\n}\n\n.feature-list li::before {\n  content: '✓';\n  color: var(--accent);\n  font-weight: 700;\n}\n\n/* IFRAME */\n.iframe-wrap {\n  background: var(--bg-card);\n  border: 1px solid var(--border);\n  border-radius: 12px;\n  overflow: hidden;\n  position: relative;\n  min-height: 700px;\n}\n\n.iframe-wrap iframe {\n  width: 100%;\n  height: 720px;\n  border: none;\n  display: block;\n}\n\n.empty-state {\n  position: absolute;\n  inset: 0;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  text-align: center;\n  padding: 32px;\n  color: var(--text-secondary);\n  background: var(--bg-card);\n}\n\n.empty-state[hidden] {\n  display: none !important;\n}\n\n/* Quick actions bar (Kalender panel) */\n.quick-actions {\n  display: grid;\n  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));\n  gap: 12px;\n  margin: 0 0 20px;\n}\n\n.qa-btn {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n  padding: 14px 16px;\n  background: var(--bg-card);\n  border: 1px solid var(--border);\n  border-radius: 10px;\n  color: var(--text-primary);\n  font-size: 0.92rem;\n  font-weight: 500;\n  transition: border-color 0.2s, transform 0.15s, background 0.2s;\n}\n\n.qa-btn:hover {\n  border-color: var(--accent);\n  background: var(--bg-card-hover);\n  transform: translateY(-1px);\n}\n\n.qa-icon {\n  font-size: 1.15rem;\n  flex-shrink: 0;\n}\n\n.qa-label {\n  flex: 1;\n}\n\n@media (max-width: 600px) {\n  .quick-actions { grid-template-columns: 1fr; }\n}\n\n/* ===== LEADS PANEL ===== */\n.panel-header {\n  display: flex;\n  align-items: flex-start;\n  justify-content: space-between;\n  gap: 16px;\n  margin-bottom: 20px;\n}\n\n.panel-header h2 { margin-bottom: 4px; }\n.panel-header .panel-sub { margin-bottom: 0; }\n\n.panel-actions {\n  display: flex;\n  gap: 10px;\n  flex-wrap: wrap;\n}\n\n.lead-website-link {\n  color: var(--accent);\n  text-decoration: none;\n  font-size: 0.85rem;\n}\n.lead-website-link:hover { text-decoration: underline; }\n\n.lead-rating {\n  display: inline-flex;\n  align-items: center;\n  gap: 4px;\n  color: var(--text-secondary);\n  font-size: 0.88rem;\n}\n.lead-rating-star { color: #fbbf24; }\n\n.lead-filters {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 8px;\n  margin-bottom: 16px;\n}\n\n.lf-btn {\n  background: var(--bg-card);\n  border: 1px solid var(--border);\n  color: var(--text-secondary);\n  padding: 6px 14px;\n  border-radius: 100px;\n  font-size: 0.82rem;\n  font-weight: 500;\n  cursor: pointer;\n  transition: all 0.15s;\n}\n\n.lf-btn:hover {\n  color: var(--text-primary);\n  border-color: var(--border-strong);\n}\n\n.lf-btn.active {\n  background: var(--accent-soft);\n  border-color: var(--accent);\n  color: var(--accent);\n}\n\n.lead-table-card {\n  padding: 0;\n  overflow: hidden;\n}\n\n.table-wrap {\n  overflow-x: auto;\n}\n\n.lead-table {\n  width: 100%;\n  border-collapse: collapse;\n  font-size: 0.9rem;\n  min-width: 700px;\n}\n\n.lead-table th,\n.lead-table td {\n  padding: 14px 16px;\n  text-align: left;\n  border-bottom: 1px solid var(--border);\n}\n\n.lead-table th {\n  background: var(--bg-secondary);\n  color: var(--text-muted);\n  font-size: 0.78rem;\n  font-weight: 600;\n  text-transform: uppercase;\n  letter-spacing: 0.04em;\n  user-select: none;\n}\n\n.lead-table th[draggable=\"true\"] {\n  cursor: grab;\n  transition: background 0.15s, color 0.15s;\n}\n\n.lead-table th[draggable=\"true\"]:hover {\n  color: var(--text-primary);\n  background: var(--bg-card-hover);\n}\n\n.lead-table th.dragging {\n  opacity: 0.4;\n  cursor: grabbing;\n}\n\n.lead-table th.drag-over {\n  background: var(--accent-soft);\n  color: var(--accent);\n  border-left: 2px solid var(--accent);\n}\n\n.lead-table tbody tr:hover {\n  background: rgba(255, 255, 255, 0.02);\n}\n\n.lead-table tbody tr:last-child td { border-bottom: none; }\n\n.lead-name-cell { font-weight: 600; color: var(--text-primary); }\n.lead-cell-muted { color: var(--text-secondary); }\n\n.status-badge {\n  display: inline-block;\n  padding: 3px 10px;\n  border-radius: 100px;\n  font-size: 0.75rem;\n  font-weight: 600;\n  text-transform: capitalize;\n}\n\n.status-new       { background: rgba(59,130,246,.15); color: #93c5fd; }\n.status-contacted { background: rgba(245,158,11,.15); color: #fcd34d; }\n.status-booked    { background: rgba(168,85,247,.15); color: #d8b4fe; }\n.status-won       { background: var(--accent-soft);   color: #86efac; }\n.status-lost      { background: rgba(239,68,68,.15);  color: #fca5a5; }\n\n.lead-actions {\n  display: flex;\n  gap: 6px;\n  justify-content: flex-end;\n}\n\n.lead-action-btn {\n  background: transparent;\n  border: 1px solid var(--border);\n  color: var(--text-secondary);\n  padding: 5px 9px;\n  border-radius: 6px;\n  font-size: 0.78rem;\n  cursor: pointer;\n  transition: all 0.15s;\n}\n\n.lead-action-btn:hover { color: var(--text-primary); border-color: var(--border-strong); }\n.lead-action-btn.danger:hover { color: var(--danger); border-color: var(--danger); }\n\n.lead-empty {\n  padding: 60px 32px;\n  text-align: center;\n  color: var(--text-secondary);\n}\n\n/* MODAL */\n.modal-backdrop {\n  position: fixed;\n  inset: 0;\n  background: rgba(0,0,0,0.7);\n  backdrop-filter: blur(4px);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  z-index: 50;\n  padding: 20px;\n}\n\n.modal-backdrop[hidden] { display: none !important; }\n\n.modal-card {\n  background: var(--bg-card);\n  border: 1px solid var(--border);\n  border-radius: 14px;\n  width: 100%;\n  max-width: 520px;\n  max-height: 90vh;\n  overflow-y: auto;\n  padding: 24px;\n}\n\n.modal-head {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  margin-bottom: 16px;\n}\n\n.modal-head h3 { font-size: 1.2rem; font-weight: 700; }\n\n.modal-close {\n  background: transparent;\n  border: none;\n  color: var(--text-secondary);\n  font-size: 1.5rem;\n  width: 32px; height: 32px;\n  border-radius: 8px;\n  line-height: 1;\n}\n\n.modal-close:hover { color: var(--text-primary); background: var(--bg-secondary); }\n\n.form-row-2 {\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  gap: 12px;\n}\n\n.form-row-2 label { margin-top: 12px; }\n\ntextarea {\n  background: var(--bg-secondary);\n  border: 1px solid var(--border);\n  color: var(--text-primary);\n  padding: 11px 14px;\n  border-radius: 8px;\n  font-size: 0.92rem;\n  font-family: inherit;\n  resize: vertical;\n}\n\ntextarea:focus { outline: none; border-color: var(--accent); }\n\n.modal-actions {\n  display: flex;\n  gap: 10px;\n  justify-content: flex-end;\n  margin-top: 24px;\n}\n\n.btn-ghost {\n  background: transparent;\n  color: var(--text-secondary);\n  border: 1px solid var(--border);\n  padding: 10px 20px;\n  border-radius: 8px;\n  font-size: 0.9rem;\n  font-weight: 600;\n  cursor: pointer;\n  font-family: inherit;\n}\n\n.btn-ghost:hover { color: var(--text-primary); border-color: var(--border-strong); }\n\n@media (max-width: 600px) {\n  .form-row-2 { grid-template-columns: 1fr; }\n  .panel-header { flex-direction: column; align-items: stretch; }\n}\n\n/* UPGRADE CARD */\n.upgrade-card {\n  background: var(--bg-card);\n  border: 1px solid var(--border);\n  border-radius: 12px;\n  padding: 48px 32px;\n  text-align: center;\n}\n\n.upgrade-icon { font-size: 2.5rem; margin-bottom: 16px; }\n\n.upgrade-card h3 {\n  font-size: 1.3rem;\n  font-weight: 700;\n  margin-bottom: 8px;\n}\n\n.upgrade-card p {\n  color: var(--text-secondary);\n  margin-bottom: 24px;\n}\n\n/* WHATSAPP */\n.wa-card { max-width: 480px; }\n\n.wa-status {\n  display: flex;\n  align-items: center;\n  gap: 10px;\n  font-weight: 600;\n  font-size: 1.05rem;\n  margin-bottom: 20px;\n}\n\n.wa-dot {\n  width: 10px; height: 10px;\n  background: var(--accent);\n  border-radius: 50%;\n  box-shadow: 0 0 8px var(--accent);\n  animation: pulse 2s ease-in-out infinite;\n}\n@keyframes pulse { 50% { opacity: 0.5; } }\n\n.wa-number {\n  margin-bottom: 24px;\n  padding-bottom: 20px;\n  border-bottom: 1px solid var(--border);\n}\n.wa-number small {\n  display: block;\n  color: var(--text-muted);\n  font-size: 0.78rem;\n  margin-bottom: 4px;\n}\n.wa-number strong { font-size: 1.1rem; }\n\n.wa-stats h4 {\n  font-size: 0.85rem;\n  color: var(--text-muted);\n  text-transform: uppercase;\n  letter-spacing: 0.05em;\n  margin-bottom: 12px;\n}\n\n.wa-stats ul {\n  list-style: none;\n  margin-bottom: 24px;\n}\n\n.wa-stats li {\n  display: flex;\n  gap: 12px;\n  align-items: baseline;\n  padding: 6px 0;\n  font-size: 0.92rem;\n  color: var(--text-secondary);\n}\n\n.wa-num {\n  color: var(--accent);\n  font-weight: 700;\n  font-size: 1.1rem;\n  min-width: 32px;\n}\n\n/* FORMS */\nform {\n  display: flex;\n  flex-direction: column;\n  gap: 4px;\n}\n\nform label {\n  font-size: 0.82rem;\n  color: var(--text-secondary);\n  font-weight: 500;\n  margin-top: 12px;\n  margin-bottom: 4px;\n}\n\nform input,\nform select {\n  background: var(--bg-secondary);\n  border: 1px solid var(--border);\n  color: var(--text-primary);\n  padding: 11px 14px;\n  border-radius: 8px;\n  font-size: 0.92rem;\n  font-family: inherit;\n}\n\nform input:focus,\nform select:focus {\n  outline: none;\n  border-color: var(--accent);\n}\n\n.btn-primary {\n  display: inline-block;\n  margin-top: 20px;\n  background: var(--accent);\n  color: #052e16;\n  border: none;\n  padding: 11px 22px;\n  border-radius: 8px;\n  font-size: 0.92rem;\n  font-weight: 700;\n  width: fit-content;\n  transition: background 0.2s;\n}\n.btn-primary:hover { background: var(--accent-hover); }\n.btn-primary:disabled { opacity: 0.6; cursor: not-allowed; }\n\n.msg {\n  margin-top: 12px;\n  font-size: 0.85rem;\n  display: none;\n}\n.msg.show { display: block; padding: 8px 12px; border-radius: 6px; }\n.msg.error { background: rgba(239, 68, 68, 0.1); color: #fca5a5; border: 1px solid rgba(239, 68, 68, 0.3); }\n.msg.success { background: var(--accent-soft); color: #86efac; border: 1px solid rgba(34, 197, 94, 0.3); }\n\n.account-email { font-size: 1rem; margin-bottom: 8px; }\n.account-plan { color: var(--text-secondary); font-size: 0.9rem; }\n\n/* RESPONSIVE */\n@media (max-width: 900px) {\n  .dashboard-layout { grid-template-columns: 1fr; }\n\n  .sidebar {\n    position: fixed;\n    top: 64px;\n    left: 0;\n    width: 240px;\n    height: calc(100vh - 64px);\n    transform: translateX(-100%);\n    transition: transform 0.25s;\n    z-index: 15;\n  }\n  .sidebar.open { transform: translateX(0); }\n\n  .hamburger { display: flex; }\n\n  .main-area { padding: 20px; }\n\n  .biz-name { display: none; }\n}\n\n@media (max-width: 500px) {\n  .topbar { padding: 0 14px; }\n  .topbar-right { gap: 8px; }\n  .logout-btn { padding: 6px 10px; font-size: 0.8rem; }\n  .panel h2 { font-size: 1.3rem; }\n}\n\n/* ===== Dashboard banners ===== */\n.dash-banner[hidden], [hidden] { display: none !important; }\n.dash-banner {\n  display: flex;\n  align-items: center;\n  gap: 16px;\n  padding: 16px 20px;\n  border-radius: 12px;\n  margin-bottom: 20px;\n  border: 1px solid;\n}\n.dash-banner.welcome { background: linear-gradient(135deg, rgba(124,58,237,0.12), rgba(168,85,247,0.06)); border-color: rgba(124,58,237,0.4); }\n.dash-banner.trial { background: rgba(245,158,11,0.08); border-color: rgba(245,158,11,0.35); }\n.dash-banner.pastdue { background: rgba(239,68,68,0.1); border-color: rgba(239,68,68,0.4); }\n.dash-banner-icon { font-size: 1.5rem; flex-shrink: 0; }\n.dash-banner-content { flex: 1; }\n.dash-banner-content strong { display: block; font-size: 0.95rem; margin-bottom: 2px; }\n.dash-banner-content p { margin: 0; font-size: 0.85rem; opacity: 0.85; line-height: 1.4; }\n.dash-banner-action {\n  background: #fff; color: #111; border: none; padding: 10px 18px; border-radius: 8px;\n  font-weight: 600; cursor: pointer; font-size: 0.9rem; white-space: nowrap;\n  transition: transform 0.15s ease;\n}\n.dash-banner-action:hover { transform: translateY(-1px); }\n.dash-banner-close {\n  background: transparent; border: none; color: inherit; font-size: 1.1rem; cursor: pointer;\n  opacity: 0.6; padding: 4px 10px;\n}\n.dash-banner-close:hover { opacity: 1; }\n\n/* ===== Cookie banner ===== */\n#cookie-banner {\n  position: fixed; bottom: 16px; left: 16px; right: 16px; max-width: 720px; margin: 0 auto;\n  background: #1a1a2e; color: #f1f0f8; padding: 16px 20px; border-radius: 12px;\n  border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 12px 40px rgba(0,0,0,0.4);\n  display: flex; gap: 12px; align-items: center; z-index: 9999; font-size: 0.9rem;\n}\n#cookie-banner p { margin: 0; flex: 1; line-height: 1.4; }\n#cookie-banner a { color: #f59e0b; text-decoration: underline; }\n#cookie-banner button {\n  background: linear-gradient(135deg, #7c3aed, #a855f7);\n  color: #fff; border: none; padding: 10px 18px; border-radius: 8px;\n  font-weight: 600; cursor: pointer; white-space: nowrap;\n}\n@media (max-width: 600px) { #cookie-banner { flex-direction: column; align-items: stretch; text-align: center; } #cookie-banner button { width: 100%; } }\n.dash-banner.pending { background: rgba(124,58,237,0.1); border-color: rgba(124,58,237,0.4); }\n.dash-banner-action { text-decoration: none; display: inline-flex; align-items: center; }\n\n/* ===== Subscription block in settings ===== */\n.sub-info p { margin: 6px 0; font-size: 0.95rem; }\n.sub-info .sub-label { display: inline-block; min-width: 200px; color: var(--text-muted, #8b8aa0); }\n.sub-actions { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 18px; }\n.btn-danger {\n  background: rgba(239,68,68,0.1); color: #ef4444; border: 1px solid rgba(239,68,68,0.4);\n  padding: 10px 18px; border-radius: 10px; font-weight: 600; cursor: pointer; font-size: 0.9rem;\n  transition: all 0.2s;\n}\n.btn-danger:hover { background: rgba(239,68,68,0.2); }\n\n/* ===== Theme toggle ===== */\n.theme-toggle-row { display: flex; gap: 10px; flex-wrap: wrap; }\n.theme-opt {\n  flex: 1; min-width: 110px; padding: 14px 18px; border-radius: 12px;\n  background: rgba(255,255,255,0.04); border: 2px solid rgba(255,255,255,0.08);\n  color: inherit; cursor: pointer; font-weight: 600; font-size: 0.95rem;\n  display: flex; align-items: center; justify-content: center; gap: 8px;\n  transition: all 0.2s;\n}\n.theme-opt:hover { border-color: rgba(124,58,237,0.4); }\n.theme-opt.active { border-color: #7c3aed; background: rgba(124,58,237,0.15); }\n\n/* ===== Light theme variables ===== */\n[data-theme=\"light\"] {\n  --dash-bg: #f8f9fc;\n  --dash-surface: #ffffff;\n  --dash-border: rgba(0,0,0,0.08);\n  --dash-text: #111118;\n  --dash-text-muted: #5a5a73;\n}\n[data-theme=\"light\"] body, [data-theme=\"light\"] .app, [data-theme=\"light\"] .main-area { background: var(--dash-bg); color: var(--dash-text); }\n[data-theme=\"light\"] .topbar, [data-theme=\"light\"] .sidebar, [data-theme=\"light\"] .panel, [data-theme=\"light\"] .card, [data-theme=\"light\"] .kpi-card { background: var(--dash-surface); border-color: var(--dash-border); color: var(--dash-text); }\n[data-theme=\"light\"] .kpi-label, [data-theme=\"light\"] .panel-sub, [data-theme=\"light\"] .sub-label { color: var(--dash-text-muted); }\n[data-theme=\"light\"] input, [data-theme=\"light\"] select, [data-theme=\"light\"] textarea { background: #fff; color: var(--dash-text); border-color: var(--dash-border); }\n[data-theme=\"light\"] .dash-banner.welcome { background: linear-gradient(135deg, #f3e8ff, #fef3c7); border-color: #c4b5fd; color: #1f1535; }\n[data-theme=\"light\"] .dash-banner.trial { background: #fffbeb; color: #78350f; border-color: #fbbf24; }\n[data-theme=\"light\"] .dash-banner.pastdue { background: #fef2f2; color: #7f1d1d; border-color: #fca5a5; }\n[data-theme=\"light\"] .dash-banner.pending { background: #f3e8ff; color: #1f1535; border-color: #c4b5fd; }\n[data-theme=\"light\"] .theme-opt { background: #f1f0f8; border-color: rgba(0,0,0,0.08); color: var(--dash-text); }\n[data-theme=\"light\"] .theme-opt.active { background: rgba(124,58,237,0.1); border-color: #7c3aed; }\n"
